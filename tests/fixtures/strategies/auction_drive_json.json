{
  "schema_version": "2.0",
  "name": "auction_drive_json",
  "description": "Auction Market Theory — intraday entries with trend context. Long + short on 1h data.",
  "parameters": {
    "min_body_pct": { "type": "float", "default": 0.2, "minimum": 0.1, "maximum": 1.0 },
    "min_rvol": { "type": "float", "default": 0.8, "minimum": 0.3, "maximum": 3.0 },
    "stop_atr_mult": { "type": "float", "default": 2.5, "minimum": 0.5, "maximum": 10.0 },
    "target_atr_mult": { "type": "float", "default": 1.5, "minimum": 0.5, "maximum": 5.0 }
  },
  "indicators": [
    { "name": "vwap",      "type": "vwap" },
    { "name": "rvol",      "type": "rvol" },
    { "name": "atr",       "type": "atr" },
    { "name": "sma_50",    "type": "sma", "period": 50 },
    { "name": "sma_200",   "type": "sma", "period": 200 }
  ],
  "features": [
    { "name": "body_up",   "type": "formula", "expr": { "op": ">",  "left": "close", "right": "open" } },
    { "name": "body_pct",  "type": "body_pct" },
    { "name": "trend_up",  "type": "formula", "expr": { "op": ">",  "left": "sma_50", "right": "sma_200" } }
  ],
  "sides": {
    "long": {
      "entry": {
        "condition": {
          "all": [
            { "left": "body_up",    "operator": "is_true" },
            { "left": "close",      "operator": ">",       "right": "vwap" },
            { "left": "body_pct",   "operator": ">=",      "right": "{{ min_body_pct }}" },
            { "left": "trend_up",   "operator": "is_true" },
            { "left": "rvol",       "operator": ">=",      "right": "{{ min_rvol }}" }
          ]
        }
      },
      "exit": {
        "condition": {
          "any": [
            { "left": "close", "operator": "<", "right": "vwap" }
          ]
        }
      }
    },
    "short": {
      "entry": {
        "condition": {
          "all": [
            { "left": "body_up",    "operator": "is_false" },
            { "left": "close",      "operator": "<",        "right": "vwap" },
            { "left": "body_pct",   "operator": ">=",       "right": "{{ min_body_pct }}" },
            { "left": "trend_up",   "operator": "is_false" },
            { "left": "rvol",       "operator": ">=",       "right": "{{ min_rvol }}" }
          ]
        }
      },
      "exit": {
        "condition": {
          "any": [
            { "left": "close", "operator": ">", "right": "vwap" }
          ]
        }
      }
    }
  },
  "risk": {
    "stop_loss":   { "type": "atr", "indicator": "atr", "multiplier": "{{ stop_atr_mult }}" },
    "take_profit": { "type": "atr", "indicator": "atr", "multiplier": "{{ target_atr_mult }}" }
  },
  "metadata": {
    "tags": ["auction_drive", "intraday", "trend_following", "long_short"]
  }
}
