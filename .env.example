# Finbar — environment configuration
# Copy to .env and adjust as needed.

# ── Data directory ─────────────────────────────────────────────────────────
# FINBAR_DATA_DIR=data

# ── yfinance rate limits ───────────────────────────────────────────────────
# YF_REQUESTS_PER_SECOND=2.0
# YF_REQUESTS_PER_MINUTE=60
# YF_MAX_RETRIES=3
# YF_BASE_BACKOFF=2.0

# ── Job manager ────────────────────────────────────────────────────────────
# FINBAR_JOB_MAX_JOBS=50
# FINBAR_JOB_TTL_SECONDS=3600

# ── MCP server ─────────────────────────────────────────────────────────────
# FINBAR_TRANSPORT=stdio        # stdio or http
# FINBAR_HOST=127.0.0.1
# FINBAR_PORT=8003

# ── REST API server ────────────────────────────────────────────────────────
# FINBAR_API_HOST=127.0.0.1
# FINBAR_API_PORT=8000
